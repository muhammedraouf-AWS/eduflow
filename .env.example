# =====================================================================
# EduFlow — environment variables
# Copy this file to `.env.local` and fill in the real values.
# Validation lives in src/lib/env.ts — the app will refuse to start if
# anything required is missing or malformed.
# =====================================================================

# ---- Runtime ----
NODE_ENV=development

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
# Recommended: Neon (https://neon.tech) — free serverless Postgres
# Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL='postgresql://neondb_owner:npg_IkLmgNzC94ay@ep-silent-night-aq8y5qiw-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# ---- Auth.js (NextAuth v5) ----
# Generate with:  openssl rand -base64 32
AUTH_SECRET=
# Optional in dev — set to your full deployed URL in production
AUTH_URL=

# ---- Google OAuth (added in Phase 1 · Step 3) ----
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---- Cloudinary ----
# Dashboard: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY='967967623976462'
CLOUDINARY_API_SECRET='ofiOEwNP6oAn95YBaSWIomcENaY'
